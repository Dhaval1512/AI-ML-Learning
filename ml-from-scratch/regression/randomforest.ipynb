   "source": [
    "from sklearn.ensemble import RandomForestClassifier\n",
    "\n",
    "X = [[1],[2],[3],[4],[6],[7],[8],[9],[10]]\n",
    "y = [0,0,0,0,1,1,0,0,0]\n",
    "\n",
    "model = RandomForestClassifier(n_estimators=10)\n",
    "model.fit(X, y)\n",
    "\n",
    "print(model.predict([[5.1]]))"
   ]
